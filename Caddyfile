{
	# Email used by Let's Encrypt for certificate expiry notices.
	email {$ACME_EMAIL:admin@genealia.fr}
}

{$SERVER_NAME:genealia.fr} {
	root * /app/public
	encode zstd gzip

	# Long-cache the versioned Webpack Encore assets.
	header /build/* Cache-Control "public, max-age=31536000, immutable"

	# Never cache HTML/dynamic pages: a new deploy ships versioned asset
	# filenames (app.<hash>.js) referenced from the HTML, so the browser must
	# always re-fetch the HTML to learn the new hash — otherwise it serves the
	# old bundle and the new JS (e.g. a new Stimulus controller) silently fails.
	@dynamic not path /build/*
	header @dynamic Cache-Control "no-cache, private"

	php_server
	file_server
}