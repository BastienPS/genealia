# Production secrets for Généalia — copy to .env.prod.local on the server and fill in.
# This file is a safe template (no real secrets); .env.prod.local is gitignored.

###> symfony/framework-bundle ###
APP_SECRET=__generate_a_64_char_hex__
###< symfony/framework-bundle ###

###> admin (in-memory) ###
# bcrypt hash of the admin password — same value as ADMIN_PASSWORD_HASH in your local .env.local
ADMIN_PASSWORD_HASH=__bcrypt_hash__
###< admin ###

###> doctrine/doctrine-bundle ###
# SQLite path inside the container (/app is the project dir). var/ is a persisted volume.
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data.db"
###< doctrine/doctrine-bundle ###

###> symfony/mailer ###
# IONOS SMTP. MAILER_FROM must be a sender authorised by IONOS.
MAILER_DSN="smtp://__user__:__password__@smtp.ionos.fr:587"
MAILER_FROM=no-reply@genealia.fr
###< symfony/mailer ###

###> knpu/oauth2-client-bundle ###
OAUTH_GOOGLE_CLIENT_ID=__google_id__
OAUTH_GOOGLE_CLIENT_SECRET=__google_secret__
OAUTH_FACEBOOK_CLIENT_ID=__facebook_id__
OAUTH_FACEBOOK_CLIENT_SECRET=__facebook_secret__
###< knpu/oauth2-client-bundle ###

###> app/paypal ###
# Lien de don PayPal (QR code géré). Même valeur que PAYPAL_DONATE_URL dans votre .env.local.
PAYPAL_DONATE_URL=__paypal_donate_url__
###< app/paypal ###