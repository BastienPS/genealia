{% extends 'base.html.twig' %}

{% block title %}{{ list.name }} - Todolist - Admin - Généalia{% endblock %}

{% block body %}
<div class="bg-brand-canvas py-12 px-6 min-h-screen">
    <div class="max-w-4xl mx-auto">
        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4 mb-8">
            <div>
                <p class="eyebrow text-brand-body mb-2">Administration · Todolist</p>
                <h1 class="text-3xl font-medium tracking-tight text-brand-ink">{{ list.name }}</h1>
            </div>
            <a href="{{ path('app_admin_todolists') }}" class="text-brand-body hover:text-brand-primary transition duration-300 text-sm">← Retour aux todolists</a>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-6 rounded-2xl border px-6 py-4 text-sm
                    {% if label == 'success' %}border-brand-mint/40 bg-brand-mint/15 text-brand-ink
                    {% else %}border-brand-orange/40 bg-brand-orange/15 text-brand-ink{% endif %}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <div class="flex flex-col sm:flex-row gap-4 mb-8">
            <form action="{{ path('app_admin_todolist_rename', {'id': list.id}) }}" method="post" class="flex-1 flex gap-3">
                <input type="hidden" name="_token" value="{{ csrf_token('rename' ~ list.id) }}">
                <input type="text" name="name" value="{{ list.name }}" class="flex-1 rounded-2xl border border-brand-hairline bg-white px-4 py-2 text-sm text-brand-ink">
                <button type="submit" class="btn-dark">Renommer</button>
            </form>
            <form action="{{ path('app_admin_todolist_delete', {'id': list.id}) }}" method="post" onsubmit="return confirm('Supprimer cette todolist et toutes ses tâches ?');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ list.id) }}">
                <button type="submit" class="btn-outline">Supprimer la liste</button>
            </form>
        </div>

        <div data-controller="todolist"
             data-todolist-reorder-url-value="{{ path('app_admin_todolist_reorder', {'id': list.id}) }}"
             data-todolist-reorder-csrf-value="{{ csrf_token('reorder' ~ list.id) }}"
             data-todolist-new-url-value="{{ path('app_admin_todotask_new', {'id': list.id}) }}"
             data-todolist-new-csrf-value="{{ csrf_token('todotask-new' ~ list.id) }}">

            <form data-turbo="false" data-action="submit->todolist#addTask" class="flex gap-3 mb-4">
                <input type="text" name="label" data-todolist-target="addInput" placeholder="Nouvelle tâche…" class="flex-1 rounded-2xl border border-brand-hairline bg-white px-4 py-2 text-sm text-brand-ink">
                <button type="submit" class="btn-cta-sm">Ajouter</button>
            </form>

            <div class="bg-brand-canvas shadow-none rounded-2xl overflow-hidden border border-brand-hairline">
                <table class="w-full text-left border-collapse">
                    <thead class="bg-brand-hairline text-brand-body">
                        <tr class="border-b border-brand-hairline">
                            <th class="eyebrow px-3 py-4 text-center w-10">⋮</th>
                            <th class="eyebrow px-6 py-4">Tâche</th>
                            <th class="eyebrow px-6 py-4 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-brand-hairline" data-todolist-target="list">
                        {% for task in list.tasks %}
                            {{ include('admin/_todo_task_row.html.twig', {'task': task}) }}
                        {% else %}
                            <tr data-todolist-target="empty" class="bg-brand-canvas">
                                <td colspan="3" class="px-6 py-12 text-center text-brand-body italic text-sm">
                                    Aucune tâche pour le moment. Ajoutez-en une ci-dessus.
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            <p class="mt-3 text-xs text-brand-body">Astuce : glissez une tâche par sa poignée ⋮ pour la réordonner.</p>
        </div>
    </div>
</div>
{% endblock %}