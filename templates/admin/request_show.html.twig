{% extends 'base.html.twig' %}

{% block title %}Détails de la demande - Généalia{% endblock %}

{% block body %}
<div class="bg-brand-canvas py-12 px-6 min-h-screen">
    <div class="max-w-4xl mx-auto">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-6 p-4 rounded-2xl border border-brand-hairline bg-brand-canvas text-sm {% if label == 'success' %}text-brand-ink{% else %}text-brand-body{% endif %}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <div class="flex justify-between items-center mb-8">
            <a href="{{ path('app_admin_requests') }}" class="text-brand-body hover:text-brand-primary transition duration-300 text-sm">← Retour à la liste</a>
            <div class="flex items-center gap-6">
                {% if app.user %}
                    <span class="text-brand-body text-sm hidden sm:inline">Connecté en tant que <span class="font-medium text-brand-ink">{{ app.user.userIdentifier }}</span></span>
                {% endif %}
                <span class="px-2 py-1 rounded-2xl bg-brand-hairline text-brand-ink text-[11px] font-mono uppercase tracking-mono-wide">
                    {{ request.status }}
                </span>
                <a href="{{ path('app_logout') }}" class="text-brand-body hover:text-brand-primary transition duration-300 text-sm">Déconnexion</a>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <!-- Details Card -->
            <div class="md:col-span-2 space-y-8">
                <div class="bg-brand-canvas p-8 rounded-2xl shadow-none border border-brand-hairline">
                    <h2 class="text-xs font-mono uppercase tracking-mono-wide text-brand-body mb-6 border-b border-brand-hairline pb-4">Informations sur l'Ancêtre</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-1">
                            <label class="block text-[10px] font-mono uppercase tracking-mono-wide text-brand-body">Nom complet</label>
                            <div class="text-lg text-brand-ink font-medium">{{ request.ancestorFirstName }} {{ request.ancestorLastName }}</div>
                        </div>
                        <div class="space-y-1">
                            <label class="block text-[10px] font-mono uppercase tracking-mono-wide text-brand-body">Date de naissance</label>
                            <div class="text-brand-ink">{{ request.estimatedBirthDate ?: 'Non précisée' }}</div>
                        </div>
                        <div class="space-y-1">
                            <label class="block text-[10px] font-mono uppercase tracking-mono-wide text-brand-body">Lieu de naissance</label>
                            <div class="text-brand-ink">{{ [request.estimatedBirthPlace, request.estimatedBirthCountry ? request.estimatedBirthCountry|country_name : null]|filter(v => v)|join(' · ') ?: 'Non précisé' }}</div>
                        </div>
                        <div class="space-y-1">
                            <label class="block text-[10px] font-mono uppercase tracking-mono-wide text-brand-body">Date de décès</label>
                            <div class="text-brand-ink">{{ request.estimatedDeathDate ?: 'Non précisée' }}</div>
                        </div>
                        <div class="space-y-1">
                            <label class="block text-[10px] font-mono uppercase tracking-mono-wide text-brand-body">Lieu de décès</label>
                            <div class="text-brand-ink">{{ [request.estimatedDeathPlace, request.estimatedDeathCountry ? request.estimatedDeathCountry|country_name : null]|filter(v => v)|join(' · ') ?: 'Non précisé' }}</div>
                        </div>
                    </div>
                    <div class="mt-8">
                        <label class="block text-[10px] font-mono uppercase tracking-mono-wide text-brand-body mb-2">Objectifs de recherche</label>
                        <div class="text-brand-ink bg-brand-canvas p-4 rounded-2xl border border-brand-hairline text-sm leading-relaxed">
                            {{ request.researchGoals ?: 'Aucun objectif spécifique précisé.' }}
                        </div>
                    </div>
                    <div class="mt-6">
                        <label class="block text-[10px] font-mono uppercase tracking-mono-wide text-brand-body mb-2">Informations complémentaires</label>
                        <div class="text-brand-body italic p-4 text-sm">
                            {{ request.additionalInfo ?: 'Aucune information supplémentaire.' }}
                        </div>
                    </div>
                </div>

                {% set research_docs = request.documents|filter(d => d.category == 'research') %}
                {% set client_docs = request.documents|filter(d => d.category == 'client') %}

                <div class="bg-brand-canvas p-8 rounded-2xl shadow-none border border-brand-hairline">
                    <h2 class="text-xs font-mono uppercase tracking-mono-wide text-brand-body mb-6 border-b border-brand-hairline pb-4">Documents trouvés</h2>

                    {% if research_docs is not empty %}
                        <ul class="divide-y divide-brand-hairline mb-6">
                            {% for document in research_docs %}
                                <li class="py-4 flex items-start justify-between gap-4">
                                    <div class="min-w-0">
                                        <div class="text-brand-ink font-medium text-sm truncate">{{ document.fileName }}</div>
                                        {% if document.description %}
                                            <div class="text-brand-body text-sm mt-1">{{ document.description }}</div>
                                        {% endif %}
                                        <div class="text-brand-body text-[11px] font-mono uppercase tracking-mono-wide mt-2">{{ document.uploadedAt|date('d/m/Y') }}</div>
                                    </div>
                                    <div class="flex items-center gap-3 flex-shrink-0">
                                        <a href="{{ path('app_admin_request_download_document', {'id': request.id, 'documentId': document.id}) }}" class="text-brand-primary hover:underline text-xs font-medium">Télécharger</a>
                                        <form action="{{ path('app_admin_document_delete', {'id': document.id}) }}" method="POST" onsubmit="return confirm('Supprimer ce document ?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ document.id) }}">
                                            <button type="submit" class="text-brand-body hover:text-brand-primary text-xs">Supprimer</button>
                                        </form>
                                    </div>
                                </li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        <div class="text-center py-10 bg-brand-canvas rounded-2xl border-2 border-dashed border-brand-hairline mb-6">
                            <p class="text-brand-body text-sm">Aucun document n'a encore été associé à cette demande.</p>
                        </div>
                    {% endif %}

                    {{ form_start(uploadForm, {'action': path('app_admin_request_upload_document', {'id': request.id}), 'attr': {'class': 'space-y-4', 'enctype': 'multipart/form-data'}}) }}
                        <div class="grid grid-cols-1 gap-4">
                            {{ form_row(uploadForm.file, {'attr': {'class': 'w-full text-sm file:mr-3 file:py-2 file:px-4 file:rounded-2xl file:border-0 file:bg-brand-primary file:text-brand-on-primary file:font-mono file:uppercase file:text-[11px] file:tracking-mono-wide file:cursor-pointer'}}) }}
                            {{ form_row(uploadForm.description, {'attr': {'class': 'w-full p-3 rounded-2xl border border-brand-hairline focus:ring-1 focus:ring-brand-primary outline-none text-sm'}}) }}
                        </div>
                        <div class="text-right">
                            <button type="submit" class="btn-cta-sm">Ajouter le document</button>
                        </div>
                    {{ form_end(uploadForm) }}
                </div>

                <div class="bg-brand-canvas p-8 rounded-2xl shadow-none border border-brand-hairline">
                    <h2 class="text-xs font-mono uppercase tracking-mono-wide text-brand-body mb-6 border-b border-brand-hairline pb-4">Pièces fournies par le client</h2>
                    {% if client_docs is not empty %}
                        <ul class="divide-y divide-brand-hairline">
                            {% for document in client_docs %}
                                <li class="py-4 flex items-center justify-between gap-4">
                                    <div class="min-w-0">
                                        <div class="text-brand-ink font-medium text-sm truncate">{{ document.fileName }}</div>
                                        <div class="text-brand-body text-[11px] font-mono uppercase tracking-mono-wide mt-2">{{ document.uploadedAt|date('d/m/Y') }}</div>
                                    </div>
                                    <a href="{{ path('app_admin_request_download_document', {'id': request.id, 'documentId': document.id}) }}" class="text-brand-primary hover:underline text-xs font-medium flex-shrink-0">Télécharger</a>
                                </li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        <p class="text-brand-body text-sm">Aucune pièce fournie par le client.</p>
                    {% endif %}
                </div>
            </div>

            <!-- Client & Status Sidebar -->
            <div class="space-y-8">
                <div class="bg-brand-canvas p-6 rounded-2xl shadow-none border border-brand-hairline">
                    <h3 class="text-xs font-mono uppercase tracking-mono-wide text-brand-body mb-4">Contact Client</h3>
                    <div class="space-y-3">
                        <div class="text-brand-ink font-medium">{{ request.clientName }}</div>
                        <div class="text-brand-body text-sm">{{ request.clientEmail }}</div>
                        {% if request.client %}
                            <a href="{{ path('app_admin_message_for_client', {'clientId': request.client.id}) }}" class="btn-cta-sm w-full text-center block mt-2">Ouvrir la messagerie</a>
                        {% else %}
                            <p class="text-brand-body text-xs mt-2 italic">Demande sans compte client associé — messagerie indisponible.</p>
                        {% endif %}
                    </div>
                </div>

                <div class="bg-brand-canvas p-6 rounded-2xl shadow-none border border-brand-hairline">
                    <h3 class="text-xs font-mono uppercase tracking-mono-wide text-brand-body mb-4">Gérer le Statut</h3>
                    <form action="{{ path('app_admin_request_update_status', {'id': request.id}) }}" method="POST" class="space-y-3">
                        <select name="status" class="w-full p-2 rounded-2xl border border-brand-hairline text-xs font-mono uppercase tracking-mono-wide outline-none bg-brand-canvas text-brand-ink">
                            <option value="pending" {% if request.status == 'pending' %}selected{% endif %}>En attente</option>
                            <option value="in_progress" {% if request.status == 'in_progress' %}selected{% endif %}>En cours</option>
                            <option value="completed" {% if request.status == 'completed' %}selected{% endif %}>Terminé</option>
                            <option value="cancelled" {% if request.status == 'cancelled' %}selected{% endif %}>Annulé</option>
                        </select>
                        <button type="submit" class="w-full btn-dark">
                            Mettre à jour
                        </button>
                    </form>
                </div>

                <div class="bg-brand-canvas p-6 rounded-2xl shadow-none border border-brand-hairline">
                    <h3 class="text-xs font-mono uppercase tracking-mono-wide text-brand-body mb-4">Todolist</h3>

                    {% set rtl = request.requestTodoList %}
                    {% if rtl %}
                        <div class="text-brand-ink font-medium text-sm mb-3">{{ rtl.name }}</div>

                        <div data-controller="todolist"
                             data-todolist-reorder-url-value="{{ path('app_admin_request_todo_reorder', {'id': rtl.id}) }}"
                             data-todolist-reorder-csrf-value="{{ csrf_token('rt-reorder' ~ rtl.id) }}">
                            <div class="rounded-2xl border border-brand-hairline overflow-hidden">
                                <table class="w-full text-left border-collapse">
                                    <thead class="bg-brand-hairline text-brand-body">
                                        <tr class="border-b border-brand-hairline">
                                            <th class="eyebrow px-3 py-3 text-center w-10">⋮</th>
                                            <th class="eyebrow px-3 py-3">Tâche</th>
                                            <th class="eyebrow px-3 py-3 text-right">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-brand-hairline" data-todolist-target="list">
                                        {% for task in rtl.tasks %}
                                            {{ include('admin/_todo_task_row.html.twig', {
                                                task: task,
                                                toggle_route: 'app_admin_request_todotask_toggle',
                                                delete_route: 'app_admin_request_todotask_delete',
                                                toggle_csrf_prefix: 'rt-toggle',
                                                delete_csrf_prefix: 'rt-delete',
                                            }) }}
                                        {% else %}
                                            <tr data-todolist-target="empty" class="bg-brand-canvas">
                                                <td colspan="3" class="px-3 py-8 text-center text-brand-body italic text-sm">
                                                    Aucune tâche dans cette todolist.
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                            <p class="mt-2 text-[11px] text-brand-body">Glissez une tâche par la poignée ⋮ pour réordonner.</p>
                        </div>

                        <form action="{{ path('app_admin_request_todo_clear', {'requestId': request.id}) }}" method="POST" onsubmit="return confirm('Retirer la todolist de cette demande ?');" class="mt-3">
                            <input type="hidden" name="_token" value="{{ csrf_token('rt-clear' ~ request.id) }}">
                            <button type="submit" class="btn-outline w-full">Retirer</button>
                        </form>
                    {% else %}
                        <p class="text-brand-body text-sm italic mb-3">Aucune todolist appliquée à cette demande.</p>
                    {% endif %}

                    <form action="{{ path('app_admin_request_todo_apply', {'requestId': request.id}) }}" method="POST" class="space-y-3 mt-4">
                        <input type="hidden" name="_token" value="{{ csrf_token('rt-apply' ~ request.id) }}">
                        <select name="todoListId" required class="w-full p-2 rounded-2xl border border-brand-hairline text-sm bg-brand-canvas text-brand-ink">
                            <option value="" disabled selected>— Choisir une todolist —</option>
                            {% for list in todo_lists %}
                                <option value="{{ list.id }}">{{ list.name }}</option>
                            {% else %}
                                <option value="" disabled>Aucune todolist configurée</option>
                            {% endfor %}
                        </select>
                        <button type="submit" class="w-full btn-dark" {% if todo_lists is empty %}disabled{% endif %}>
                            {{ rtl ? 'Remplacer' : 'Appliquer' }}
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
