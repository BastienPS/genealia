{% extends 'base.html.twig' %}

{% block title %}Administration - Demandes de Recherche{% endblock %}

{% block body %}
<div class="bg-brand-canvas py-12 px-6 min-h-screen">
    <div class="max-w-6xl mx-auto">
        <div class="flex justify-between items-center mb-8">
            <h1 class="text-3xl font-medium tracking-tight text-brand-ink">Gestion des Demandes</h1>
            <div class="flex items-center gap-6">
                {% if app.user %}
                    <span class="text-brand-body text-sm">Connecté en tant que <span class="font-medium text-brand-ink">{{ app.user.userIdentifier }}</span></span>
                {% endif %}
                <a href="{{ path('app_admin_clients') }}" class="text-brand-body hover:text-brand-primary transition duration-300 text-sm">Clients</a>
                <a href="{{ path('app_home') }}" class="text-brand-body hover:text-brand-primary transition duration-300 text-sm">← Retour au site</a>
                <a href="{{ path('app_logout') }}" class="text-brand-body hover:text-brand-primary transition duration-300 text-sm">Déconnexion</a>
            </div>
        </div>

        <div class="flex justify-end mb-4">
            {% if archived %}
                <a href="{{ path('app_admin_requests') }}" class="text-brand-body hover:text-brand-primary transition duration-300 text-sm">← Voir les demandes actives</a>
            {% else %}
                <a href="{{ path('app_admin_requests', {'archived': 1}) }}" class="text-brand-body hover:text-brand-primary transition duration-300 text-sm">Voir les demandes archivées</a>
            {% endif %}
        </div>

        <div class="bg-brand-canvas shadow-none rounded-2xl overflow-hidden border border-brand-hairline">
            <table class="w-full text-left border-collapse">
                <thead class="bg-brand-hairline text-brand-body">
                    <tr class="border-b border-brand-hairline">
                        <th class="eyebrow px-6 py-4">Client</th>
                        <th class="eyebrow px-6 py-4">Ancêtre</th>
                        <th class="eyebrow px-6 py-4">Date</th>
                        <th class="eyebrow px-6 py-4">Statut</th>
                        <th class="eyebrow px-6 py-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-brand-hairline">
                    {% for request in requests %}
                        <tr class="hover:bg-stone-50 transition duration-150">
                            <td class="px-6 py-4">
                                <div class="font-medium text-brand-ink">{{ request.clientName }}</div>
                                <div class="text-xs text-brand-body">{{ request.clientEmail }}</div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="text-brand-ink">{{ request.ancestorFirstName }} {{ request.ancestorLastName }}</div>
                            </td>
                            <td class="px-6 py-4 text-brand-body text-xs">
                                {{ request.createdAt|date('d/m/Y') }}
                            </td>
                            <td class="px-6 py-4">
                                {% if request.deletionRequested %}
                                    <span class="block mb-1 px-2 py-1 rounded-2xl bg-brand-magenta/20 text-brand-ink text-[11px] font-mono uppercase tracking-mono-wide">Suppression demandée</span>
                                {% endif %}
                                {% if request.status == 'pending' %}
                                    <span class="px-2 py-1 rounded-2xl bg-brand-hairline text-brand-ink text-[11px] font-mono uppercase tracking-mono-wide">En attente</span>
                                {% elseif request.status == 'in_progress' %}
                                    <span class="px-2 py-1 rounded-2xl bg-brand-orange/25 text-brand-ink text-[11px] font-mono uppercase tracking-mono-wide">En cours</span>
                                {% elseif request.status == 'completed' %}
                                    <span class="px-2 py-1 rounded-2xl bg-brand-periwinkle/35 text-brand-ink text-[11px] font-mono uppercase tracking-mono-wide">Terminé</span>
                                {% elseif request.status == 'archived' %}
                                    <span class="px-2 py-1 rounded-2xl bg-brand-hairline text-brand-body text-[11px] font-mono uppercase tracking-mono-wide">Archivée</span>
                                {% else %}
                                    <span class="px-2 py-1 rounded-2xl bg-brand-hairline text-brand-body text-[11px] font-mono uppercase tracking-mono-wide">{{ request.status }}</span>
                                {% endif %}
                            </td>
                            <td class="px-6 py-4 text-right">
                                <a href="{{ path('app_admin_request_show', {'id': request.id}) }}" class="inline-flex items-center font-mono uppercase text-[11px] tracking-mono-wide font-medium px-4 py-2 rounded-2xl text-brand-ink border border-brand-hairline bg-brand-canvas transition duration-300 hover:border-brand-ink">Détails</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr class="bg-brand-canvas">
                            <td colspan="5" class="px-6 py-12 text-center text-brand-body italic text-sm">
                                Aucune demande de recherche pour le moment.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
