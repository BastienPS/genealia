{% extends 'base.html.twig' %}

{% block title %}Todolists - Admin - Généalia{% endblock %}

{% block body %}
<div class="bg-brand-canvas py-12 px-6 min-h-screen">
    <div class="max-w-5xl mx-auto">
        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4 mb-8">
            <div>
                <p class="eyebrow text-brand-body mb-2">Administration</p>
                <h1 class="text-3xl font-medium tracking-tight text-brand-ink">Todolists</h1>
            </div>
            <a href="{{ path('app_admin_requests') }}" class="text-brand-body hover:text-brand-primary transition duration-300 text-sm">← Retour aux demandes</a>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-6 rounded-2xl border px-6 py-4 text-sm
                    {% if label == 'success' %}border-brand-mint/40 bg-brand-mint/15 text-brand-ink
                    {% else %}border-brand-orange/40 bg-brand-orange/15 text-brand-ink{% endif %}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <form action="{{ path('app_admin_todolist_new') }}" method="post" class="flex gap-3 mb-8 max-w-md">
            <input type="text" name="name" placeholder="Nom de la nouvelle todolist…" required class="flex-1 rounded-2xl border border-brand-hairline bg-white px-4 py-2 text-sm text-brand-ink">
            <button type="submit" class="btn-cta-sm">Créer</button>
        </form>

        <div class="bg-brand-canvas shadow-none rounded-2xl overflow-hidden border border-brand-hairline">
            <table class="w-full text-left border-collapse">
                <thead class="bg-brand-hairline text-brand-body">
                    <tr class="border-b border-brand-hairline">
                        <th class="eyebrow px-6 py-4">Nom</th>
                        <th class="eyebrow px-6 py-4">Tâches</th>
                        <th class="eyebrow px-6 py-4">Créée le</th>
                        <th class="eyebrow px-6 py-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-brand-hairline">
                    {% for list in todo_lists %}
                        <tr class="hover:bg-stone-50 transition duration-150">
                            <td class="px-6 py-4">
                                <a href="{{ path('app_admin_todolist_show', {'id': list.id}) }}" class="font-medium text-brand-ink hover:text-brand-primary transition">{{ list.name }}</a>
                            </td>
                            <td class="px-6 py-4 text-sm text-brand-body">{{ list.tasks|length }}</td>
                            <td class="px-6 py-4 text-brand-body text-xs">{{ list.createdAt ? list.createdAt|date('d/m/Y') : '—' }}</td>
                            <td class="px-6 py-4 text-right">
                                <div class="inline-flex items-center gap-2">
                                    <a href="{{ path('app_admin_todolist_show', {'id': list.id}) }}" class="inline-flex items-center font-mono uppercase text-[11px] tracking-mono-wide font-medium px-4 py-2 rounded-2xl text-brand-ink border border-brand-hairline bg-brand-canvas transition duration-300 hover:border-brand-ink">Ouvrir</a>
                                    <form method="post" action="{{ path('app_admin_todolist_delete', {'id': list.id}) }}" onsubmit="return confirm('Supprimer cette todolist et toutes ses tâches ?');" class="inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ list.id) }}">
                                        <button type="submit" class="inline-flex items-center font-mono uppercase text-[11px] tracking-mono-wide font-medium px-4 py-2 rounded-2xl text-brand-ink border border-brand-hairline bg-brand-canvas transition duration-300 hover:border-brand-magenta hover:text-brand-magenta">Suppr</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr class="bg-brand-canvas">
                            <td colspan="4" class="px-6 py-12 text-center text-brand-body italic text-sm">
                                Aucune todolist pour le moment. Créez-en une ci-dessus.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}