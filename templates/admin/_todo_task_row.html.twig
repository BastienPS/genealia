{# Ligne d'une tâche — rendu initial ET fragment retourné par app_admin_todotask_new (AJAX).
   Le contrôleur Stimulus `todolist` lit les data-* pour toggle/delete, et gère le drag.
   Routes/CSRF paramétrables : defaults = configurateur (phase 1) ; la fiche demande
   (phase 2) passe des overrides pour cibler les routes snapshot request_todo. #}
{% set toggle_route = toggle_route|default('app_admin_todotask_toggle') %}
{% set delete_route = delete_route|default('app_admin_todotask_delete') %}
{% set toggle_csrf_prefix = toggle_csrf_prefix|default('toggle') %}
{% set delete_csrf_prefix = delete_csrf_prefix|default('delete') %}
<tr class="hover:bg-stone-50 transition duration-150 {% if task.done %}opacity-60{% endif %}"
    data-todolist-target="task"
    data-id="{{ task.id }}"
    data-toggle-url="{{ path(toggle_route, {'id': task.id}) }}"
    data-delete-url="{{ path(delete_route, {'id': task.id}) }}"
    data-toggle-csrf="{{ csrf_token(toggle_csrf_prefix ~ task.id) }}"
    data-delete-csrf="{{ csrf_token(delete_csrf_prefix ~ task.id) }}"
    draggable="true"
    data-action="dragstart->todolist#dragstart dragover->todolist#dragover drop->todolist#drop dragend->todolist#dragend">
    <td class="px-3 py-4 text-center cursor-grab select-none text-brand-body" title="Glisser pour réordonner">⋮</td>
    <td class="px-6 py-4">
        <span class="js-task-label text-brand-ink {% if task.done %}line-through text-brand-body{% endif %}">{{ task.label }}</span>
    </td>
    <td class="px-6 py-4 text-right whitespace-nowrap">
        <div class="inline-flex items-center gap-2">
            <button type="button" data-action="click->todolist#toggleDone" title="{{ task.done ? 'Annuler (tâche faite)' : 'Marquer comme fait' }}"
                class="js-toggle-btn inline-flex items-center justify-center p-2 rounded-2xl border border-brand-hairline bg-brand-canvas transition duration-300 hover:border-brand-ink {% if task.done %}text-brand-mint{% else %}text-brand-ink{% endif %}">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round" class="pointer-events-none" {% if task.done %}fill="currentColor" stroke="none"{% else %}fill="none" stroke="currentColor" stroke-width="3"{% endif %}><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            </button>
            <button type="button" data-action="click->todolist#deleteTask" title="Supprimer la tâche"
                class="inline-flex items-center justify-center p-2 rounded-2xl text-brand-ink border border-brand-hairline bg-brand-canvas transition duration-300 hover:border-brand-magenta hover:text-brand-magenta">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pointer-events-none"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
            </button>
        </div>
    </td>
</tr>