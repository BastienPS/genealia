{# Mail automatique envoyé au client quand l'admin répond dans le fil. #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vous avez reçu un message de votre généalogiste</title>
</head>
<body style="margin:0;padding:0;background:#f4f4f5;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#18181b;">
    <table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="background:#f4f4f5;padding:24px 0;">
        <tr>
            <td align="center">
                <table width="560" cellpadding="0" cellspacing="0" role="presentation" style="background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 1px 2px rgba(0,0,0,0.04);">
                    <tr>
                        <td style="padding:28px 32px 8px;font-size:20px;font-weight:700;color:#0f172a;">
                            Généalia
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:8px 32px 0;font-size:18px;font-weight:600;color:#0f172a;">
                            Vous avez reçu un message de votre généalogiste
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:8px 32px 0;font-size:15px;line-height:1.6;color:#52525b;">
                            Bonjour {{ client_name }},
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:12px 32px 0;">
                            <table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="background:#f4f4f5;border-left:3px solid #4f46e5;border-radius:6px;">
                                <tr>
                                    <td style="padding:16px 18px;font-size:15px;line-height:1.6;color:#27272a;white-space:pre-wrap;">{{ message_content }}</td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:20px 32px 0;font-size:15px;line-height:1.6;color:#52525b;">
                            Pour répondre, ouvrez votre espace descendant&nbsp;:
                        </td>
                    </tr>
                    <tr>
                        <td align="center" style="padding:12px 32px 28px;">
                            <a href="{{ thread_url }}" style="display:inline-block;background:#4f46e5;color:#ffffff;text-decoration:none;font-weight:600;font-size:15px;padding:12px 24px;border-radius:8px;">Ouvrir la messagerie</a>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:0 32px 24px;font-size:13px;line-height:1.5;color:#a1a1aa;border-top:1px solid #e4e4e7;padding-top:18px;">
                            Vous recevez ce courriel car un généalogiste de Généalia vous a écrit dans votre dossier. Ne répondez pas directement à ce message&nbsp;: utilisez la messagerie de votre espace.
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>