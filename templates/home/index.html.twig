{% extends 'base.html.twig' %}

{% block title %}Généalia - Votre expert en recherches généalogiques{% endblock %}

{% block body %}
<div class="flex flex-col">
    <!-- Hero -->
    <section class="relative bg-brand-canvas-dark text-brand-on-dark overflow-hidden">
        <div class="absolute inset-0 pointer-events-none">
            <div class="absolute -top-24 -right-24 h-96 w-96 rounded-full bg-brand-orange opacity-30 blur-3xl mix-blend-screen"></div>
            <div class="absolute top-1/3 -right-10 h-80 w-80 rounded-full bg-brand-magenta opacity-30 blur-3xl mix-blend-screen"></div>
            <div class="absolute -bottom-24 right-1/4 h-72 w-72 rounded-full bg-brand-periwinkle opacity-30 blur-3xl mix-blend-screen"></div>
        </div>

        <div class="relative z-10 max-w-7xl mx-auto px-6 py-28 md:py-36 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div>
                <span class="eyebrow text-brand-on-dark/70">Généalogie professionnelle</span>
                <h1 class="mt-5 text-4xl md:text-6xl font-medium tracking-tightest leading-[1.05]">
                    Retrouvez vos <span class="gradient-text">ancêtres</span>,<br>
                    généalogie après généalogie.
                </h1>
                <p class="mt-6 text-lg text-brand-on-dark/80 max-w-xl leading-relaxed font-normal">
                    Vous souhaitez explorer votre histoire familiale mais ne savez pas par où commencer ? Je mets mon expertise et mon temps à votre service pour effectuer vos recherches en archives.
                </p>
                <div class="mt-10 flex flex-wrap gap-4">
                    <a href="{{ path('app_request_new') }}" class="btn-cta">Déposer une demande</a>
                    <a href="#how-it-works" class="btn-outline-dark">Comment ça marche ?</a>
                </div>
            </div>

            <!-- Brand ribbon panel -->
            <div class="relative hidden lg:block">
                <div class="relative aspect-square rounded-sm border border-brand-surface-dark-soft overflow-hidden bg-brand-canvas-dark/40">
                    <div class="absolute inset-0 bg-brand-gradient opacity-90"></div>
                    <div class="absolute -top-10 -left-10 h-56 w-56 rounded-full bg-brand-magenta opacity-60 blur-2xl mix-blend-screen"></div>
                    <div class="absolute bottom-0 right-0 h-64 w-64 rounded-full bg-brand-periwinkle opacity-60 blur-2xl mix-blend-screen"></div>
                    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-center">
                        <span class="font-mono uppercase text-xs tracking-mono-wide text-white/80">Archives · Registres · Actes</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Gradient ribbon strip -->
        <div class="h-1 w-full bg-brand-gradient"></div>
    </section>

    <!-- Stats -->
    <section class="py-20 px-6 bg-brand-canvas">
        <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="bg-brand-mint rounded-sm p-8">
                <div class="text-5xl font-medium tracking-tightest text-brand-ink">250+</div>
                <div class="eyebrow mt-3">Ancêtres retrouvés</div>
            </div>
            <div class="bg-brand-periwinkle rounded-sm p-8">
                <div class="text-5xl font-medium tracking-tightest text-brand-ink">12 ans</div>
                <div class="eyebrow mt-3">D'expérience en archives</div>
            </div>
            <div class="bg-brand-mint rounded-sm p-8">
                <div class="text-5xl font-medium tracking-tightest text-brand-ink">8</div>
                <div class="eyebrow mt-3">Archives départementales</div>
            </div>
        </div>
    </section>

    <!-- How It Works -->
    <section id="how-it-works" class="py-24 px-6 bg-brand-canvas">
        <div class="max-w-6xl mx-auto">
            <div class="text-center mb-16">
                <span class="eyebrow">Processus</span>
                <h2 class="mt-4 text-3xl md:text-4xl font-medium tracking-tight text-brand-ink">Un accompagnement simple et efficace</h2>
                <div class="rule-gradient mx-auto mt-6"></div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="group p-8 rounded-sm bg-brand-canvas border border-brand-hairline transition duration-300 hover:-translate-y-1 hover:shadow-brand-glow">
                    <div class="h-14 w-14 rounded-full bg-brand-gradient text-white flex items-center justify-center text-xl font-medium">1</div>
                    <h3 class="mt-6 text-xl font-medium text-brand-ink">Déposez vos indices</h3>
                    <p class="mt-3 text-brand-body leading-relaxed">
                        Remplissez un formulaire simple avec les noms, dates et lieux que vous connaissez. Plus vous donnez d'indices, plus la recherche est précise.
                    </p>
                </div>

                <div class="group p-8 rounded-sm bg-brand-canvas border border-brand-hairline transition duration-300 hover:-translate-y-1 hover:shadow-brand-glow">
                    <div class="h-14 w-14 rounded-full bg-brand-gradient text-white flex items-center justify-center text-xl font-medium">2</div>
                    <h3 class="mt-6 text-xl font-medium text-brand-ink">Je mène l'enquête</h3>
                    <p class="mt-3 text-brand-body leading-relaxed">
                        Je parcours les archives départementales, les registres paroissiaux et les bases de données spécialisées pour retrouver vos ancêtres.
                    </p>
                </div>

                <div class="group p-8 rounded-sm bg-brand-canvas border border-brand-hairline transition duration-300 hover:-translate-y-1 hover:shadow-brand-glow">
                    <div class="h-14 w-14 rounded-full bg-brand-gradient text-white flex items-center justify-center text-xl font-medium">3</div>
                    <h3 class="mt-6 text-xl font-medium text-brand-ink">Récupérez vos documents</h3>
                    <p class="mt-3 text-brand-body leading-relaxed">
                        Une fois la recherche terminée, je dépose les actes et documents trouvés dans votre espace personnel sécurisé.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Value Proposition -->
    <section class="py-24 px-6 bg-brand-canvas-dark text-brand-on-dark">
        <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center gap-12">
            <div class="md:w-1/2">
                <div class="relative aspect-square rounded-sm border border-brand-surface-dark-soft overflow-hidden">
                    <div class="absolute inset-0 bg-brand-gradient opacity-80"></div>
                    <div class="absolute -top-8 -left-8 h-48 w-48 rounded-full bg-brand-magenta opacity-60 blur-2xl mix-blend-screen"></div>
                    <div class="absolute -bottom-8 -right-8 h-56 w-56 rounded-full bg-brand-periwinkle opacity-60 blur-2xl mix-blend-screen"></div>
                </div>
            </div>
            <div class="md:w-1/2">
                <span class="eyebrow text-brand-on-dark/70">Pourquoi me choisir ?</span>
                <h2 class="mt-4 text-3xl md:text-4xl font-medium tracking-tight text-brand-on-dark">L'expertise humaine au service de vos racines</h2>
                <div class="mt-8 space-y-5">
                    <div class="flex gap-4">
                        <div class="flex-shrink-0 h-6 w-6 rounded-full bg-brand-gradient flex items-center justify-center text-white text-xs font-bold">✓</div>
                        <p class="text-brand-on-dark/85"><strong class="text-brand-on-dark">Gain de temps</strong> — inutile de passer des heures à déchiffrer des écritures anciennes.</p>
                    </div>
                    <div class="flex gap-4">
                        <div class="flex-shrink-0 h-6 w-6 rounded-full bg-brand-gradient flex items-center justify-center text-white text-xs font-bold">✓</div>
                        <p class="text-brand-on-dark/85"><strong class="text-brand-on-dark">Rigueur méthodologique</strong> — meilleures sources et vérification croisée des données.</p>
                    </div>
                    <div class="flex gap-4">
                        <div class="flex-shrink-0 h-6 w-6 rounded-full bg-brand-gradient flex items-center justify-center text-white text-xs font-bold">✓</div>
                        <p class="text-brand-on-dark/85"><strong class="text-brand-on-dark">Livraison claire</strong> — documents organisés et commentés, dans votre espace personnel.</p>
                    </div>
                </div>
                <div class="mt-10">
                    <a href="{{ path('app_request_new') }}" class="btn-cta">Déposer une demande</a>
                </div>
            </div>
        </div>
    </section>
</div>
{% endblock %}