{% extends 'base.html.twig' %}

{% block title %}Espace des descendants - Généalia{% endblock %}

{% block body %}
<div class="bg-brand-canvas py-12 px-6 min-h-screen">
    <div class="max-w-6xl mx-auto">
        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4 mb-8">
            <div>
                <p class="eyebrow text-brand-body mb-2">Espace des descendants</p>
                <h1 class="text-3xl font-medium tracking-tight text-brand-ink">Mes demandes de recherche</h1>
            </div>
            <div class="flex items-center gap-6">
                {% if app.user %}
                    <span class="text-brand-body text-sm hidden sm:inline">Bonjour <span class="font-medium text-brand-ink">{{ app.user.firstName }}</span></span>
                {% endif %}
                <a href="{{ path('app_client_messages') }}" class="inline-flex items-center gap-2 font-mono uppercase text-[11px] tracking-mono-wide font-medium px-4 py-2 rounded-2xl text-brand-ink border border-brand-hairline bg-brand-canvas transition duration-300 hover:border-brand-ink">
                    Messagerie
                    {% if messageUnreadCount > 0 %}
                        <span class="px-1.5 py-0.5 rounded-2xl bg-brand-primary text-brand-on-primary text-[10px]">{{ messageUnreadCount }}</span>
                    {% endif %}
                </a>
                <a href="{{ path('app_request_new') }}" class="btn-cta-sm">Déposer une nouvelle demande</a>
            </div>
        </div>

        {% set pending_deletions = requests|filter(r => r.deletionRequested) %}
        {% if pending_deletions|length > 0 %}
            <div class="mb-6 p-5 rounded-2xl border border-brand-magenta/40 bg-brand-magenta/10">
                <p class="text-brand-ink font-medium text-sm mb-3">Le généalogiste demande la suppression de {{ pending_deletions|length }} demande(s) — à confirmer ou refuser :</p>
                <ul class="space-y-1">
                    {% for r in pending_deletions %}
                        <li class="text-sm">
                            <a href="{{ path('app_client_request_show', {'id': r.id}) }}" class="text-brand-primary hover:underline">{{ r.ancestorFirstName }} {{ r.ancestorLastName }}</a>
                        </li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}

        <div class="bg-brand-canvas shadow-none rounded-2xl overflow-hidden border border-brand-hairline">
            <table class="w-full text-left border-collapse">
                <thead class="bg-brand-hairline text-brand-body">
                    <tr class="border-b border-brand-hairline">
                        <th class="eyebrow px-6 py-4">Ancêtre</th>
                        <th class="eyebrow px-6 py-4">Date</th>
                        <th class="eyebrow px-6 py-4">Statut</th>
                        <th class="eyebrow px-6 py-4">Documents</th>
                        <th class="eyebrow px-6 py-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-brand-hairline">
                    {% for request in requests %}
                        <tr class="hover:bg-stone-50 transition duration-150">
                            <td class="px-6 py-4">
                                <div class="text-brand-ink">{{ request.ancestorFirstName }} {{ request.ancestorLastName }}</div>
                            </td>
                            <td class="px-6 py-4 text-brand-body text-xs">
                                {{ request.createdAt|date('d/m/Y') }}
                            </td>
                            <td class="px-6 py-4">
                                {% if request.deletionRequested %}
                                    <span class="block mb-1 px-2 py-1 rounded-2xl bg-brand-magenta/20 text-brand-ink text-[11px] font-mono uppercase tracking-mono-wide">Suppression demandée</span>
                                {% endif %}
                                {% if request.status == 'pending' %}
                                    <span class="px-2 py-1 rounded-2xl bg-brand-hairline text-brand-ink text-[11px] font-mono uppercase tracking-mono-wide">En attente</span>
                                {% elseif request.status == 'in_progress' %}
                                    <span class="px-2 py-1 rounded-2xl bg-brand-orange/25 text-brand-ink text-[11px] font-mono uppercase tracking-mono-wide">En cours</span>
                                {% elseif request.status == 'completed' %}
                                    <span class="px-2 py-1 rounded-2xl bg-brand-periwinkle/35 text-brand-ink text-[11px] font-mono uppercase tracking-mono-wide">Terminé</span>
                                {% else %}
                                    <span class="px-2 py-1 rounded-2xl bg-brand-hairline text-brand-body text-[11px] font-mono uppercase tracking-mono-wide">{{ request.status }}</span>
                                {% endif %}
                            </td>
                            <td class="px-6 py-4 text-brand-body text-xs">
                                {{ request.documents|length }}
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="inline-flex items-center gap-2">
                                    <a href="{{ path('app_client_request_show', {'id': request.id}) }}" class="inline-flex items-center font-mono uppercase text-[11px] tracking-mono-wide font-medium px-4 py-2 rounded-2xl text-brand-ink border border-brand-hairline bg-brand-canvas transition duration-300 hover:border-brand-ink">Détails</a>
                                    <form action="{{ path('app_client_request_delete', {'id': request.id}) }}" method="POST" onsubmit="return confirm('Supprimer (archiver) cette demande ? Cette action la retirera de votre espace.');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('client-delete' ~ request.id) }}">
                                        <button type="submit" title="Supprimer cette demande" class="inline-flex items-center justify-center p-2 rounded-2xl text-brand-magenta border border-brand-hairline bg-brand-canvas transition duration-300 hover:border-brand-magenta">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pointer-events-none"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr class="bg-brand-canvas">
                            <td colspan="5" class="px-6 py-12 text-center">
                                <div class="border-2 border-dashed border-brand-hairline rounded-2xl py-10 px-6">
                                    <p class="text-brand-body text-sm mb-6">Vous n'avez encore déposé aucune demande.</p>
                                    <a href="{{ path('app_request_new') }}" class="btn-cta">Déposer une demande</a>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {% if archived_requests|length > 0 %}
            <div class="mt-10">
                <h2 class="text-xs font-mono uppercase tracking-mono-wide text-brand-body mb-4">Archivées ({{ archived_requests|length }})</h2>
                <div class="bg-brand-canvas shadow-none rounded-2xl overflow-hidden border border-brand-hairline">
                    <table class="w-full text-left border-collapse">
                        <thead class="bg-brand-hairline text-brand-body">
                            <tr class="border-b border-brand-hairline">
                                <th class="eyebrow px-6 py-4">Ancêtre</th>
                                <th class="eyebrow px-6 py-4">Date</th>
                                <th class="eyebrow px-6 py-4">Statut</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-brand-hairline">
                            {% for request in archived_requests %}
                                <tr class="opacity-60">
                                    <td class="px-6 py-4">
                                        <div class="text-brand-ink">{{ request.ancestorFirstName }} {{ request.ancestorLastName }}</div>
                                    </td>
                                    <td class="px-6 py-4 text-brand-body text-xs">
                                        {{ request.createdAt|date('d/m/Y') }}
                                    </td>
                                    <td class="px-6 py-4">
                                        <span class="px-2 py-1 rounded-2xl bg-brand-hairline text-brand-body text-[11px] font-mono uppercase tracking-mono-wide">Archivée</span>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                <p class="mt-2 text-[11px] text-brand-body">Les demandes archivées sont conservées en lecture seule. Pour en restaurer une, contactez le généalogiste.</p>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}