{% extends 'base.html.twig' %}

{% block title %}Ma demande - Généalia{% endblock %}

{% block body %}
<div class="bg-brand-canvas py-12 px-6 min-h-screen">
    <div class="max-w-4xl mx-auto">
        <div class="flex justify-between items-center mb-8">
            <a href="{{ path('app_client_space') }}" class="text-brand-body hover:text-brand-primary transition duration-300 text-sm">← Retour à mon espace</a>
            <div class="flex items-center gap-6">
                <span class="px-2 py-1 rounded-2xl bg-brand-hairline text-brand-ink text-[11px] font-mono uppercase tracking-mono-wide">
                    {% if request.status == 'pending' %}En attente
                    {% elseif request.status == 'in_progress' %}En cours
                    {% elseif request.status == 'completed' %}Terminé
                    {% else %}{{ request.status }}{% endif %}
                </span>
            </div>
        </div>

        {% if request.deletionRequested %}
            <div class="mb-8 p-6 rounded-2xl border border-brand-magenta/40 bg-brand-magenta/10">
                <p class="text-brand-ink font-medium mb-2">Le généalogiste demande la suppression de cette demande.</p>
                <p class="text-brand-body text-sm mb-5">Vous pouvez confirmer la suppression (la demande sera archivée et disparaîtra de votre espace) ou refuser (elle sera conservée).</p>
                <div class="flex flex-wrap items-center gap-3">
                    <form action="{{ path('app_client_request_confirm_deletion', {'id': request.id}) }}" method="POST" onsubmit="return confirm('Confirmer la suppression de cette demande ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('client-confirm-deletion' ~ request.id) }}">
                        <button type="submit" class="btn-cta">Confirmer la suppression</button>
                    </form>
                    <form action="{{ path('app_client_request_refuse_deletion', {'id': request.id}) }}" method="POST">
                        <input type="hidden" name="_token" value="{{ csrf_token('client-refuse-deletion' ~ request.id) }}">
                        <button type="submit" class="btn-outline">Refuser</button>
                    </form>
                </div>
            </div>
        {% endif %}

        <div class="space-y-8">
            <!-- Informations sur l'Ancêtre -->
            <div class="bg-brand-canvas p-8 rounded-2xl shadow-none border border-brand-hairline">
                <h2 class="text-xs font-mono uppercase tracking-mono-wide text-brand-body mb-6 border-b border-brand-hairline pb-4">Informations sur l'Ancêtre</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-1">
                        <label class="block text-[10px] font-mono uppercase tracking-mono-wide text-brand-body">Nom complet</label>
                        <div class="text-lg text-brand-ink font-medium">{{ request.ancestorFirstName }} {{ request.ancestorLastName }}</div>
                    </div>
                    <div class="space-y-1">
                        <label class="block text-[10px] font-mono uppercase tracking-mono-wide text-brand-body">Date de naissance</label>
                        <div class="text-brand-ink">{{ request.estimatedBirthDate ?: 'Non précisée' }}</div>
                    </div>
                    <div class="space-y-1">
                        <label class="block text-[10px] font-mono uppercase tracking-mono-wide text-brand-body">Lieu de naissance</label>
                        <div class="text-brand-ink">{{ [request.estimatedBirthPlace, request.estimatedBirthCountry ? request.estimatedBirthCountry|country_name : null]|filter(v => v)|join(' · ') ?: 'Non précisé' }}</div>
                    </div>
                    <div class="space-y-1">
                        <label class="block text-[10px] font-mono uppercase tracking-mono-wide text-brand-body">Date de décès</label>
                        <div class="text-brand-ink">{{ request.estimatedDeathDate ?: 'Non précisée' }}</div>
                    </div>
                    <div class="space-y-1">
                        <label class="block text-[10px] font-mono uppercase tracking-mono-wide text-brand-body">Lieu de décès</label>
                        <div class="text-brand-ink">{{ [request.estimatedDeathPlace, request.estimatedDeathCountry ? request.estimatedDeathCountry|country_name : null]|filter(v => v)|join(' · ') ?: 'Non précisé' }}</div>
                    </div>
                    <div class="space-y-1">
                        <label class="block text-[10px] font-mono uppercase tracking-mono-wide text-brand-body">Déposée le</label>
                        <div class="text-brand-ink">{{ request.createdAt|date('d/m/Y') }}</div>
                    </div>
                </div>
                <div class="mt-8">
                    <label class="block text-[10px] font-mono uppercase tracking-mono-wide text-brand-body mb-2">Objectifs de recherche</label>
                    <div class="text-brand-ink bg-brand-canvas p-4 rounded-2xl border border-brand-hairline text-sm leading-relaxed">
                        {{ request.researchGoals ?: 'Aucun objectif spécifique précisé.' }}
                    </div>
                </div>
                <div class="mt-6">
                    <label class="block text-[10px] font-mono uppercase tracking-mono-wide text-brand-body mb-2">Informations complémentaires</label>
                    <div class="text-brand-body italic p-4 text-sm">
                        {{ request.additionalInfo ?: 'Aucune information supplémentaire.' }}
                    </div>
                </div>
            </div>

            {% set research_docs = request.documents|filter(d => d.category == 'research') %}
            {% set client_docs = request.documents|filter(d => d.category == 'client') %}

            <!-- Documents trouvés par le généalogiste -->
            <div class="bg-brand-canvas p-8 rounded-2xl shadow-none border border-brand-hairline">
                <h2 class="text-xs font-mono uppercase tracking-mono-wide text-brand-body mb-6 border-b border-brand-hairline pb-4">Documents trouvés par le généalogiste</h2>

                {% if research_docs is not empty %}
                    <ul class="divide-y divide-brand-hairline">
                        {% for document in research_docs %}
                            <li class="py-4 flex items-start justify-between gap-4">
                                <div class="min-w-0">
                                    <div class="text-brand-ink font-medium text-sm truncate">{{ document.fileName }}</div>
                                    {% if document.description %}
                                        <div class="text-brand-body text-sm mt-1">{{ document.description }}</div>
                                    {% endif %}
                                    <div class="text-brand-body text-[11px] font-mono uppercase tracking-mono-wide mt-2">{{ document.uploadedAt|date('d/m/Y') }}</div>
                                </div>
                                <a href="{{ path('app_client_download_document', {'id': request.id, 'documentId': document.id}) }}" class="text-brand-primary hover:underline text-xs font-medium flex-shrink-0">Télécharger</a>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <div class="text-center py-10 bg-brand-canvas rounded-2xl border-2 border-dashed border-brand-hairline">
                        <p class="text-brand-body text-sm">Le généalogiste n'a pas encore partagé de document pour cette demande.</p>
                    </div>
                {% endif %}
            </div>

            <!-- Mes pièces déposées -->
            <div class="bg-brand-canvas p-8 rounded-2xl shadow-none border border-brand-hairline">
                <h2 class="text-xs font-mono uppercase tracking-mono-wide text-brand-body mb-6 border-b border-brand-hairline pb-4">Mes pièces déposées</h2>
                {% if client_docs is not empty %}
                    <ul class="divide-y divide-brand-hairline">
                        {% for document in client_docs %}
                            <li class="py-4 flex items-start justify-between gap-4">
                                <div class="min-w-0">
                                    <div class="text-brand-ink font-medium text-sm truncate">{{ document.fileName }}</div>
                                    <div class="text-brand-body text-[11px] font-mono uppercase tracking-mono-wide mt-2">{{ document.uploadedAt|date('d/m/Y') }}</div>
                                </div>
                                <a href="{{ path('app_client_download_document', {'id': request.id, 'documentId': document.id}) }}" class="text-brand-primary hover:underline text-xs font-medium flex-shrink-0">Télécharger</a>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <div class="text-center py-10 bg-brand-canvas rounded-2xl border-2 border-dashed border-brand-hairline">
                        <p class="text-brand-body text-sm">Vous n'avez déposé aucune pièce pour cette demande.</p>
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="mt-8 p-6 rounded-2xl border border-brand-hairline bg-brand-canvas">
            <h2 class="text-xs font-mono uppercase tracking-mono-wide text-brand-body mb-3">Supprimer cette demande</h2>
            <p class="text-brand-body text-sm mb-5">Vous pouvez à tout moment supprimer (archiver) cette demande. Elle disparaîtra alors de votre espace.</p>
            <form action="{{ path('app_client_request_delete', {'id': request.id}) }}" method="POST" onsubmit="return confirm('Supprimer (archiver) cette demande ?');">
                <input type="hidden" name="_token" value="{{ csrf_token('client-delete' ~ request.id) }}">
                <button type="submit" class="btn-dark">Supprimer cette demande</button>
            </form>
        </div>
    </div>
</div>
{% endblock %}