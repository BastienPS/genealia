<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body class="bg-brand-canvas text-brand-ink font-sans antialiased" data-turbo-prefetch="false">
        <header class="sticky top-0 z-50 bg-brand-canvas-dark text-brand-on-dark border-b border-brand-surface-dark-soft">
            <nav class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
                <a href="{{ path('app_home') }}" class="flex items-center gap-2 hover:opacity-80 transition duration-300">
                    <span class="h-2.5 w-2.5 rounded-full bg-brand-gradient"></span>
                    <span class="text-2xl font-medium tracking-tightest">Généalia</span>
                </a>
                <div class="hidden md:flex items-center gap-8 text-brand-on-dark font-normal">
                    <a href="{{ path('app_home') }}" class="hover:opacity-80 transition duration-300 text-sm">Accueil</a>
                    <a href="{{ path('app_home') }}#how-it-works" class="hover:opacity-80 transition duration-300 text-sm">Comment ça marche ?</a>
                    <a href="{{ path('app_legal_apropos') }}" class="hover:opacity-80 transition duration-300 text-sm">À propos</a>
                </div>
                <div class="flex items-center gap-4">
                    {% if app.user %}
                        <div class="relative" data-controller="dropdown">
                            <button type="button" data-action="click->dropdown#toggle" class="flex items-center gap-1.5 text-brand-on-dark hover:opacity-80 font-medium transition duration-300 text-sm">
                                <span>Bonjour</span>
                                <span class="hidden sm:inline">{{ is_granted('ROLE_ADMIN') ? app.user.userIdentifier : app.user.firstName }}</span>
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="pointer-events-none"><polyline points="6 9 12 15 18 9"/></svg>
                            </button>
                            <div data-dropdown-target="menu" class="hidden absolute right-0 top-full mt-2 w-60 rounded-2xl border border-brand-surface-dark-soft bg-brand-canvas-dark text-brand-on-dark shadow-lg overflow-hidden z-50">
                                <div class="px-4 py-3 text-xs text-brand-on-dark/70 border-b border-brand-surface-dark-soft truncate">Connecté en tant que {{ app.user.userIdentifier }}</div>
                                {% if is_granted('ROLE_ADMIN') %}
                                    <a href="{{ path('app_admin_requests') }}" class="block px-4 py-2.5 text-sm hover:bg-brand-surface-dark-soft transition duration-150">Demandes</a>
                                    <a href="{{ path('app_admin_clients') }}" class="block px-4 py-2.5 text-sm hover:bg-brand-surface-dark-soft transition duration-150">Clients</a>
                                    <a href="{{ path('app_admin_todolists') }}" class="block px-4 py-2.5 text-sm hover:bg-brand-surface-dark-soft transition duration-150">Todolist</a>
                                    <a href="{{ path('app_admin_messages') }}" class="block px-4 py-2.5 text-sm hover:bg-brand-surface-dark-soft transition duration-150">Messagerie</a>
                                {% else %}
                                    <a href="{{ path('app_client_space') }}" class="block px-4 py-2.5 text-sm hover:bg-brand-surface-dark-soft transition duration-150">Mon espace</a>
                                    <a href="{{ path('app_client_ancestors') }}" class="block px-4 py-2.5 text-sm hover:bg-brand-surface-dark-soft transition duration-150">Mes ancêtres</a>
                                    <a href="{{ path('app_client_messages') }}" class="block px-4 py-2.5 text-sm hover:bg-brand-surface-dark-soft transition duration-150">Messagerie</a>
                                {% endif %}
                                <div class="border-t border-brand-surface-dark-soft">
                                    <a href="{{ path('app_logout') }}" data-turbo="false" class="block px-4 py-2.5 text-sm hover:bg-brand-surface-dark-soft transition duration-150">Déconnexion</a>
                                </div>
                            </div>
                        </div>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="text-brand-on-dark hover:opacity-80 font-medium transition duration-300 text-sm hidden sm:inline">Connexion</a>
                    {% endif %}
                    <a href="{{ path('app_request_new') }}" class="btn-cta-sm">Déposer une demande</a>
                </div>
            </nav>
        </header>

        <main>
            {% block body %}{% endblock %}
        </main>

        <footer class="bg-brand-canvas text-brand-ink pt-20 px-6">
            <div class="h-1 w-full bg-brand-gradient"></div>
            <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-12 mt-16">
                <div class="col-span-1">
                    <div class="flex items-center gap-2">
                        <span class="h-2.5 w-2.5 rounded-full bg-brand-gradient"></span>
                        <span class="text-xl font-medium tracking-tightest">Généalia</span>
                    </div>
                    <p class="text-brand-body text-sm mt-4 leading-relaxed">
                        L'expertise humaine au service de votre histoire familiale.
                    </p>
                </div>
                <div>
                    <h4 class="eyebrow mb-4">Service</h4>
                    <ul class="space-y-2 text-sm">
                        <li><a href="{{ path('app_home') }}" class="hover:text-brand-primary transition">Accueil</a></li>
                        <li><a href="{{ path('app_home') }}#how-it-works" class="hover:text-brand-primary transition">Comment ça marche ?</a></li>
                        <li><a href="{{ path('app_request_new') }}" class="hover:text-brand-primary transition">Déposer une demande</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="eyebrow mb-4">Légal</h4>
                    <ul class="space-y-2 text-sm">
                        <li><a href="{{ path('app_legal_apropos') }}" class="hover:text-brand-primary transition">À propos</a></li>
                        <li><a href="{{ path('app_legal_mentions') }}" class="hover:text-brand-primary transition">Mentions légales</a></li>
                        <li><a href="{{ path('app_legal_confidentialite') }}" class="hover:text-brand-primary transition">Confidentialité</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="eyebrow mb-4">Contact</h4>
                    <ul class="space-y-2 text-sm">
                        <li><a href="{{ path('app_contact') }}" class="hover:text-brand-primary transition">Email</a></li>
                        <li><a href="#" class="hover:text-brand-primary transition">LinkedIn</a></li>
                    </ul>
                </div>
            </div>
            <div class="max-w-7xl mx-auto mt-20 pt-8 border-t border-brand-hairline text-center">
                <span class="text-7xl md:text-9xl font-medium tracking-tightest text-brand-hairline opacity-60 select-none">GÉNÉALIA</span>
            </div>
        </footer>
    </body>
</html>
